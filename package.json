{
  "name": "terra-pulse",
  "version": "0.0.1",
  "type": "module",
  "scripts": {
    "dev": "astro dev",
    "start": "astro dev",
    "build": "astro build",
    "deploy": "bun run build && npx wrangler deploy",
    "deploy:dry-run": "npx wrangler deploy --dry-run",
    "preview": "astro preview",
    "lint": "oxlint",
    "format": "oxfmt",
    "prepare": "husky",
    "lint:fix": "oxlint --fix . && oxfmt",
    "check": "astro check"
  },
  "dependencies": {
    "@tailwindcss/vite": "^4.2.1",
    "astro": "^6.0.5"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4.2.1",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "oxfmt": "^0.41.0",
    "oxlint": "^1.56.0",
    "tailwindcss": "^4.2.1"
  },
  "lint-staged": {
    "*.{js,jsx,ts,tsx}": [
      "oxlint --fix",
      "oxfmt"
    ]
  },
  "packageManager": "bun@1.2.0"
}
