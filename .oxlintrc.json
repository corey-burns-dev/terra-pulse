{
  "$schema": "./node_modules/oxlint/configuration_schema.json",
  "plugins": ["eslint", "oxc", "unicorn"],
  "categories": {
    "correctness": "warn",
    "suspicious": "warn",
    "perf": "warn"
  },
  "rules": {
    "eslint/no-shadow": "off",
    "eslint/no-await-in-loop": "off"
  },
  "env": {
    "builtin": true
  },
  "globals": {},
  "ignorePatterns": [".astro", "dist", "node_modules", "bun.lock"]
}
